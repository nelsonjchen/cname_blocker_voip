# Copy this file to .env for local testing:
# cp .env.example .env

# Required for real VoIP.ms registration.
VOIPMS_USER=123456_blocker
VOIPMS_PASSWORD=replace-me
VOIPMS_HOST=losangeles1.voip.ms

# Optional SIP settings.
VOIPMS_PORT=5060
SIP_NAT=true
NAT_KEEPALIVE_SECS=15
REGISTER_EXPIRY_SECS=60
REGISTER_RETRY_SECS=5
REGISTER_MAX_RETRY=3

# Use "nelson" for local/manual testing, then switch to "pch" for production.
BLOCK_CNAME_PATTERNS=nelson
# Optional comma-separated, case-insensitive Rust regexes for caller names/From headers.
# This example blocks city/state CNAM values like "UPLAND CA" or "BREA CA".
# BLOCK_CNAME_REGEXES=[[:alpha:]] CA$

# Optional Twilio Lookup caller-name source. When both are set, Twilio Lookup
# is used for matching instead of VoIP.ms/SIP upstream CNAME.
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=replace-me
TWILIO_LOOKUP_TIMEOUT_MS=1500

# Optional fixed RTP range. Leave both as 0 to let the OS choose ports.
RTP_PORT_MIN=0
RTP_PORT_MAX=0

# Optional replacement message. Supports .ogg/.opus or .wav.
# BLOCKER_MESSAGE_AUDIO=/absolute/path/to/message.ogg

RUST_LOG=info,xphone::sip::client=warn,xphone::phone=warn
LOG_ANSI=false
LOG_TIMESTAMPS=false
